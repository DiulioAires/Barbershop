// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id   String @id @default(uuid()) //primary key
  NAME String
  bookings Booking[] // Define the relation to Booking
}


model Barbershop {
  id   String @id @default(uuid())
  NAME String
  address String
  imageUrl String
  services Service[] // Define the relation to Service
  bookings Booking[] // Define the relation to Booking
}


model Service {
  id            String    @id @default(uuid())
  NAME          String
  price         Decimal   @db.Decimal(10, 2)
  description   String
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id])
  imageUrl      String    // Add an image URL field for the service
  bookings      Booking[]

}

model Booking {
  id String @id @default(uuid())
  user User @relation(fields: [userId], references: [id]) // Define the relation to User
  userId String
  service Service @relation(fields: [serviceId], references: [id]) // Define the relation to Service
  serviceId String
  date DateTime
  barbershop Barbershop @relation(fields: [barbershopId], references: [id]) // Define the relation to Barbershop
  barbershopId String
  status String
}